.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.sln
*.suo
*.sdf
*.opensdf
*.user

# OS cruft
Thumbs.db
.DS_Store

# Note: .github/ (README screenshots) is intentionally NOT ignored.
